<StepExposure>:
    name: "exposure"
    BoxLayout:
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        MDTopAppBar:
            title: "Pozlama Ayarları"
            elevation: 0

        MDLabel:
            text: "Adım 3/5 - Pozlama"
            font_style: "H5"
            size_hint_y: None
            height: dp(36)

        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)

                # kV
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(8)
                    MDTextField:
                        id: kv_input
                        hint_text: "kV"
                        text: str(app.state.kv)
                        input_filter: "float"
                        size_hint_x: 0.3
                        on_text: root.on_kv(self.text)
                    MDSlider:
                        id: kv_slider
                        size_hint_x: 0.7
                        min: 1.0
                        max: 1000.0
                        value: app.state.kv
                        on_value: root.on_slider_kv(args[1])

                # mA
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(8)
                    MDTextField:
                        id: ma_input
                        hint_text: "mA"
                        text: str(app.state.ma)
                        input_filter: "float"
                        size_hint_x: 0.3
                        on_text: root.on_ma(self.text)
                    MDSlider:
                        id: ma_slider
                        size_hint_x: 0.7
                        min: 0.1
                        max: 50.0
                        value: app.state.ma
                        on_value: root.on_slider_ma(args[1])

                # Time
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(8)
                    MDTextField:
                        id: time_input
                        hint_text: "Süre (sn)"
                        text: str(app.state.exposure_time)
                        input_filter: "float"
                        size_hint_x: 0.3
                        on_text: root.on_time(self.text)
                    MDSlider:
                        id: time_slider
                        size_hint_x: 0.7
                        min: 0.1
                        max: 3600.0
                        value: app.state.exposure_time
                        on_value: root.on_slider_time(args[1])

                # SFD
                BoxLayout:
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(8)
                    MDTextField:
                        id: sfd_input
                        hint_text: "SFD (mm)"
                        text: str(app.state.sfd)
                        input_filter: "float"
                        size_hint_x: 0.3
                        on_text: root.on_sfd(self.text)
                    MDSlider:
                        id: sfd_slider
                        size_hint_x: 0.7
                        min: 10.0
                        max: 5000.0
                        value: app.state.sfd
                        on_value: root.on_slider_sfd(args[1])

                # Film area (visible only for analog)
                BoxLayout:
                    id: film_area
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(4)
                    MDRaisedButton:
                        id: film_class_btn
                        text: app.state.film_class
                        size_hint_x: 1
                        size_hint_y: None
                        height: dp(48)
                        on_release: root.open_film_menu()

                # Detector area (visible only for digital)
                BoxLayout:
                    id: detector_area
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(4)
                    MDRaisedButton:
                        id: detector_btn
                        text: "Detector"
                        size_hint_x: 1
                        size_hint_y: None
                        height: dp(48)
                        on_release: root.open_detector_menu()

                # Source side IQI
                MDSwitch:
                    active: app.state.source_side_iqi
                    on_active: root.on_source_side_change(args[1])

        Widget:
            size_hint_y: 1

        MDRaisedButton:
            text: "HESAPLA"
            size_hint_x: 1
            size_hint_y: None
            height: dp(52)
            md_bg_color: app.theme_cls.accent_color
            on_release: root.on_calculate()
